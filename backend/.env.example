# Flask Environment
FLASK_ENV=development

# Auth0 Config
AUTH0_DOMAIN=your-auth0-domain.auth0.com
API_AUDIENCE=https://your-api-audience-url
ALGORITHMS=RS256

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_RESULT_BACKEND=redis://redis:6379/1

# # CORS Config
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Rate Limiting
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/2
DEFAULT_RATE_LIMIT=1000 per hour

# Feed Parser Settings (currently hardcoded in constants.py)
FEED_ITEM_LIMIT=500
FEED_REQUEST_TIMEOUT=10
FEED_REQUEST_RETRIES=2

# Celery Settings (some are hardcoded in make_celery.py)
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_WORKER_MAX_TASKS_PER_CHILD=50

LOG_LEVEL=INFO