# Flask Environment
FLASK_ENV=development

# Auth0 Config
AUTH0_DOMAIN=your-auth0-domain.auth0.com
API_AUDIENCE=https://your-api-audience-url
ALGORITHMS=RS256

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_RESULT_BACKEND=redis://redis:6379/1

# Database
# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/test_dbname
PROD_DATABASE_URL=postgresql://user:password@localhost:5432/prod_dbname

# # CORS Config
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Rate Limiting
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/2
DEFAULT_RATE_LIMIT=1000 per hour

# Logging
LOG_LEVEL=INFO

# Flask Security
SECRET_KEY=<random-secure-string>  # For session management and JWT signing in tests
FLASK_DEBUG=false  # Should be false in production

# Gunicorn Settings (currently hardcoded in entrypoint.sh)
GUNICORN_WORKERS=4
GUNICORN_PORT=8000
GUNICORN_HOST=0.0.0.0

# Feed Parser Settings (currently hardcoded in constants.py)
FEED_ITEM_LIMIT=500
FEED_REQUEST_TIMEOUT=10
FEED_REQUEST_RETRIES=2

# Request Limits (currently hardcoded in constants.py)
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# Celery Settings (some are hardcoded in make_celery.py)
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_WORKER_MAX_TASKS_PER_CHILD=50