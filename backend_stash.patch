diff --git a/backend/openapi/bundled.yaml b/backend/openapi/bundled.yaml
new file mode 100644
index 0000000..7eb7215
--- /dev/null
+++ b/backend/openapi/bundled.yaml
@@ -0,0 +1,310 @@
+openapi: 3.0.0
+info:
+  title: Podverse Admin API
+  version: 1.0.0
+  description: Admin API for Podverse podcast platform dashboard
+servers:
+  - description: Local development
+    url: http://localhost:8000/admin
+security:
+  - Auth0Bearer: []
+paths:
+  /feeds:
+    get:
+      summary: Retrieve a list of RSS feeds
+      description: Returns a paginated list of feeds including parsing status, errors, and basic metadata.
+      tags:
+        - Feeds
+      security:
+        - Auth0Bearer: []
+      parameters:
+        - $ref: '#/components/parameters/limit'
+        - $ref: '#/components/parameters/offset'
+        - $ref: '#/components/parameters/search'
+      responses:
+        '200':
+          description: List of feeds returned
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  data:
+                    type: array
+                    items:
+                      $ref: '#/components/schemas/Feed'
+                  meta:
+                    type: object
+                    properties:
+                      total:
+                        type: integer
+                      limit:
+                        type: integer
+  /feeds/{id}/reparse:
+    post:
+      summary: Trigger RSS reparse
+      description: Tells backend to refetch and reprocess feed by ID
+      tags:
+        - Feeds
+      security:
+        - Auth0Bearer: []
+      parameters:
+        - name: id
+          in: path
+          required: true
+          schema:
+            type: integer
+      responses:
+        '200':
+          description: Reparse triggered
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  message:
+                    type: string
+  /channels:
+    get:
+      summary: Retrieve a list of channels
+      description: Returns a paginated list of channels with their metadata and status
+      tags:
+        - Channels
+      security:
+        - Auth0Bearer: []
+      parameters:
+        - $ref: '#/components/parameters/limit'
+        - $ref: '#/components/parameters/offset'
+        - $ref: '#/components/parameters/search'
+      responses:
+        '200':
+          description: List of channels returned
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  data:
+                    type: array
+                    items:
+                      $ref: '#/components/schemas/Channel'
+                  meta:
+                    type: object
+                    properties:
+                      total:
+                        type: integer
+                      limit:
+                        type: integer
+                      offset:
+                        type: integer
+        '401':
+          description: Unauthorized
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  error:
+                    type: string
+                    example: Unauthorized access
+    post:
+      summary: Create a new channel
+      description: Creates a new channel with the provided information
+      tags:
+        - Channels
+      security:
+        - Auth0Bearer: []
+      requestBody:
+        required: true
+        content:
+          application/json:
+            schema:
+              type: object
+              properties:
+                name:
+                  type: string
+                  description: Name of the channel
+                  example: New Tech Channel
+                description:
+                  type: string
+                  description: Channel description
+                  example: A new channel for tech content
+              required:
+                - name
+      responses:
+        '201':
+          description: Channel created successfully
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Channel'
+        '401':
+          description: Unauthorized
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  error:
+                    type: string
+                    example: Unauthorized access
+  /channels/{id}:
+    get:
+      summary: Get channel by ID
+      description: Retrieves a specific channel by its ID
+      tags:
+        - Channels
+      security:
+        - Auth0Bearer: []
+      parameters:
+        - name: id
+          in: path
+          required: true
+          schema:
+            type: integer
+          description: Channel ID
+      responses:
+        '200':
+          description: Channel found
+          content:
+            application/json:
+              schema:
+                $ref: '#/components/schemas/Channel'
+        '401':
+          description: Unauthorized
+          content:
+            application/json:
+              schema:
+                type: object
+                properties:
+                  error:
+                    type: string
+                    example: Unauthorized access
+components:
+  parameters:
+    limit:
+      name: limit
+      in: query
+      required: false
+      schema:
+        type: integer
+        minimum: 1
+        maximum: 100
+      description: Max number of results to return
+    offset:
+      name: offset
+      in: query
+      required: false
+      schema:
+        type: integer
+        minimum: 0
+      description: Number of results to skip for pagination
+    search:
+      name: search
+      in: query
+      required: false
+      schema:
+        type: string
+      description: Search by ...
+  schemas:
+    Feed:
+      type: object
+      properties:
+        id:
+          type: integer
+          description: Feed ID (primary key)
+          example: 104
+        url:
+          type: string
+          format: uri
+          description: RSS feed URL
+          example: https://example.com/rss.xml
+        created_at:
+          type: string
+          format: date-time
+          description: Timestamp when feed was added
+        updated_at:
+          type: string
+          format: date-time
+          description: Last time the feed record was updated
+        is_parsing:
+          type: boolean
+          description: Whether feed is currently being parsed
+        last_parsed:
+          type: string
+          format: date-time
+          description: Last time parsing was attempted
+          nullable: true
+        feed_flag_status_id:
+          type: integer
+          description: ID from feed_flag_status table (status type)
+        last_error:
+          type: string
+          description: Last parsing error message (from feed_health)
+          nullable: true
+          example: Timeout while fetching
+        last_successful_parse:
+          type: string
+          format: date-time
+          description: Last time parsing succeeded (from feed_health)
+          nullable: true
+        is_valid_rss:
+          type: boolean
+          description: Whether the RSS was determined to be valid
+          example: true
+        channel_id:
+          type: integer
+          description: ID of linked channel (if exists)
+          nullable: true
+    Channel:
+      type: object
+      properties:
+        id:
+          type: integer
+          description: Unique identifier for the channel
+          example: 1
+        name:
+          type: string
+          description: Name of the channel
+          example: Tech Talk Channel
+        description:
+          type: string
+          description: Channel description
+          example: A channel dedicated to technology discussions
+        created_at:
+          type: string
+          format: date-time
+          description: When the channel was created
+          example: '2024-01-15T10:30:00Z'
+        updated_at:
+          type: string
+          format: date-time
+          description: When the channel was last updated
+          example: '2024-01-15T10:30:00Z'
+        is_active:
+          type: boolean
+          description: Whether the channel is active
+          example: true
+        subscriber_count:
+          type: integer
+          description: Number of subscribers
+          example: 1250
+      required:
+        - id
+        - name
+        - created_at
+        - is_active
+  responses:
+    Unauthorized:
+      description: Unauthorized – invalid or missing JWT
+      content:
+        application/json:
+          schema:
+            type: object
+            properties:
+              error:
+                type: string
+                example: Unauthorized
+              message:
+                type: string
+                example: Authentication token is invalid or expired.
