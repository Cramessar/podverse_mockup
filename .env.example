# Firebase Client SDK config (used in frontend and server)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ListenNotes API key (server only)
LISTENNOTES_API_KEY=your-listennotes-api-key

# Admin emails (comma separated) for client-side checks (optional, if you still want to use it)
NEXT_PUBLIC_ADMIN_EMAILS=admin1@example.com,admin2@example.com
